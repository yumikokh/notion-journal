# Client-side (Expo) env vars — used by the app to reach Supabase.
# Copy this file to `.env.local` (gitignored) and fill in real values.
#
# `EXPO_PUBLIC_*` is auto-exposed at build time by Expo SDK 49+.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# ---------------------------------------------------------------------------
# The following are SERVER-SIDE secrets — set via `supabase secrets set ...`,
# NOT in this .env file. Listed here only for documentation.
#
#   NOTION_TOKEN=secret_xxx         # Notion Internal Integration token
#   NOTION_DB_ID=9d854c37-a54c-...  # 2026/Daily DB id
#   ANTHROPIC_API_KEY=sk-ant-xxx    # Claude API key
#
# See `supabase/README.md` for the full setup.
